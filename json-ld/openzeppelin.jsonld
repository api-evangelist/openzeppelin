{
  "@context": {
    "@vocab": "https://schema.org/",
    "oz": "https://docs.openzeppelin.com/vocab#",
    "defender": "https://defender-api.openzeppelin.com/v2/",
    "relayer": "https://docs.openzeppelin.com/relayer/",

    "RelayerResponse": "oz:RelayerResponse",
    "NetworkResponse": "oz:NetworkResponse",
    "NotificationResponse": "oz:NotificationResponse",
    "SignerResponse": "oz:SignerResponse",
    "TransactionResponse": "oz:TransactionResponse",
    "BalanceResponse": "oz:BalanceResponse",
    "RelayerStatus": "oz:RelayerStatus",
    "PluginModel": "oz:PluginModel",

    "id": "@id",
    "type": "@type",
    "name": "schema:name",
    "description": "schema:description",
    "status": "oz:status",
    "network": "oz:network",
    "address": "oz:address",
    "balance": "oz:balance",
    "nonce": "oz:nonce",
    "gasPrice": "oz:gasPrice",
    "maxFeePerGas": "oz:maxFeePerGas",
    "maxPriorityFeePerGas": "oz:maxPriorityFeePerGas",
    "transactionId": "oz:transactionId",
    "hash": "oz:hash",
    "from": "oz:from",
    "to": "oz:to",
    "value": "oz:value",
    "data": "oz:data",
    "chainId": "oz:chainId",
    "speed": "oz:speed",
    "signerType": "oz:signerType",
    "policy": "oz:policy",
    "notificationType": "oz:notificationType",
    "relayerId": "oz:relayerId",
    "networkId": "oz:networkId",
    "notificationId": "oz:notificationId",
    "signerId": "oz:signerId",
    "pluginId": "oz:pluginId",
    "createdAt": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },
    "updatedAt": {
      "@id": "schema:dateModified",
      "@type": "xsd:dateTime"
    },
    "paused": "oz:paused",
    "systemType": "oz:systemType",
    "minBalance": "oz:minBalance",
    "pendingTransactions": "oz:pendingTransactions",
    "lastConfirmedAt": "oz:lastConfirmedAt",
    "rpcUrl": "oz:rpcUrl",
    "symbol": "oz:symbol",
    "decimals": "oz:decimals",
    "isEnabled": "oz:isEnabled",
    "version": "schema:version",
    "metadata": "oz:metadata"
  }
}
