{
  "title": "Send EVM Transaction via OpenZeppelin Relayer",
  "description": "Example of sending a blockchain transaction through the OpenZeppelin Relayer API on an EVM-compatible network.",
  "request": {
    "method": "POST",
    "url": "http://localhost:8080/api/v1/relayers/{relayer_id}/transactions",
    "headers": {
      "Authorization": "Bearer {api_key}",
      "Content-Type": "application/json"
    },
    "body": {
      "to": "0xRecipientAddress",
      "value": "1000000000000000000",
      "data": "0x",
      "speed": "fast",
      "gas_limit": 21000,
      "valid_until": "2026-06-13T12:00:00Z"
    }
  },
  "response": {
    "status": 201,
    "body": {
      "success": true,
      "data": {
        "id": "tx-uuid-1234",
        "hash": null,
        "status": "pending",
        "from": "0xRelayerAddress",
        "to": "0xRecipientAddress",
        "value": "1000000000000000000",
        "data": "0x",
        "nonce": 42,
        "gas_limit": 21000,
        "speed": "fast",
        "chain_id": 1,
        "created_at": "2026-06-13T10:00:00Z",
        "sent_at": null,
        "confirmed_at": null,
        "valid_until": "2026-06-13T12:00:00Z"
      },
      "message": "Transaction submitted successfully"
    }
  }
}
